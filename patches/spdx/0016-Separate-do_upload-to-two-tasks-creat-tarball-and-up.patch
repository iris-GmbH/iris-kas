+def get_tarball_name(d, srcdir, suffix, ar_outdir):
+    """
+    get the tarball file path
+    """
+    import tarfile, shutil
+
+    srcdir = os.path.realpath(srcdir)
+
+    filename = get_tar_name(d, suffix)
+    tarname = os.path.join(ar_outdir, filename)
+    return tarname
+
